# Copy to .env and fill in. .env is gitignored — never commit real keys.

# College Scorecard API (free key from https://api.data.gov/signup/)
# Used in Phase 4 for socio-economic context. Not needed for Phase 1.
SCORECARD_API_KEY=

# Urban Institute Education Data API (IPEDS) needs NO key.
# Base: https://educationdata.urban.org/api/v1/college-university/ipeds/{topic}/{year}/

# Model provider (Phase 3). Provider-swappable: gemini | ollama | claude
PEERLENS_MODEL_PROVIDER=gemini
GEMINI_API_KEY=
# Default model is gemini-2.5-flash (gemini-2.0-flash has 0 free-tier quota on
# some keys). Free tier is ~5 requests/min; the agent makes agent_samples (5)
# requests per question, so space questions out or lower AGENT_SAMPLES.
# GEMINI_MODEL=gemini-2.5-flash
# AGENT_SAMPLES=5
ANTHROPIC_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
